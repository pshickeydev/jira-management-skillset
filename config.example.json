      "securityLevel": "Internal",
      "commentVisibility": {
        "type": "role",
        "value": "Developers"
      },
      "customFields": {
        "Story Points": "customfield_XXXXX",
        "Sprint": "customfield_XXXXX"
      },
      "defaultLabels": ["team-example"],
      "defaultComponents": ["backend"]
    }
  }
}
