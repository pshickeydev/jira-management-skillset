{
  "cloudId": "yoursite.atlassian.net",
  "assignToSelf": true,
  "aiDisclaimer": true,
  "configured_at": "",

  "defaults": {
    "project": "MYPROJ",
    "issueType": "Task",
    "priority": "Normal",
    "labels": [],
